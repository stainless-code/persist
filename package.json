    "alpine",
    "angular",
    "broadcastchannel",
    "codec",
    "compression",
    "cross-tab",
    "encryption",
    "hydration",
    "indexeddb",
    "jotai",
    "lit",
    "localstorage",
    "middleware",
    "migration",
    "mmkv",
    "mobx",
    "persistence",
    "pinia",
    "preact",
