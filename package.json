    "./sources/redux": {
      "types": "./dist/sources/redux.d.mts",
      "import": "./dist/sources/redux.mjs"
    },
    "./frameworks/react": {
      "types": "./dist/frameworks/react.d.mts",
      "import": "./dist/frameworks/react.mjs"
    },
    "./frameworks/preact": {
      "types": "./dist/frameworks/preact.d.mts",
