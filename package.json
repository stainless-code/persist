    },
    "./frameworks/lit": {
      "types": "./dist/frameworks/lit.d.mts",
      "import": "./dist/frameworks/lit.mjs"
    },
    "./frameworks/alpine": {
      "types": "./dist/frameworks/alpine.d.mts",
      "import": "./dist/frameworks/alpine.mjs"
