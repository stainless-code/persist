  "bugs": {
    "url": "https://github.com/stainless-code/persist/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stainless-code/persist.git"
  },
  "workspaces": [
    ".",
    "apps/*"
  ],
  "files": [
    "dist",
    "skills",
    "!skills/_artifacts"
  ],
