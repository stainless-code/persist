---
import { contentHref } from "blume/components/content/base-href.ts";
import InstallBox from "./InstallBox.astro";

const primaryButton =
  "inline-flex items-center gap-2 rounded-full bg-foreground px-5 py-2.5 font-medium text-background text-sm transition-opacity hover:opacity-90";
const secondaryButton =
  "inline-flex items-center gap-2 rounded-full border border-border px-5 py-2.5 font-medium text-foreground text-sm transition-colors hover:border-foreground";
---

<section class="border-border border-y px-6 py-16 text-center sm:px-12 sm:py-20">
  <h2
    class="mx-auto max-w-2xl text-balance font-medium text-3xl tracking-tight sm:text-4xl"
  >
    Start persisting without the flash.
  </h2>
  <p class="mx-auto mt-4 max-w-lg text-balance text-muted-foreground">
    Install the core, then add peers only for the subpaths you import.
  </p>
  <div class="mt-8"><InstallBox /></div>
  <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
    <a class={secondaryButton} href={contentHref("/concepts/three-seams")}>
      Browse concepts
    </a>
    <a class={primaryButton} href={contentHref("/guides/getting-started")}>
      Get started
      <svg
        fill="none"
        height="16"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        width="16"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="m9 18 6-6-6-6"></path>
      </svg>
    </a>
  </div>
</section>
