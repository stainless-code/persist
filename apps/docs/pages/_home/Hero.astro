---
import CodeBlock from "blume/components/content/CodeBlock.astro";
import Icon from "blume/components/Icon.astro";
import { contentHref } from "blume/components/content/base-href.ts";
import InstallBox from "./InstallBox.astro";
import { defaultSourceId, sourceSnippets } from "./source-snippets.ts";

const pillBase =
  "cursor-pointer rounded-full border px-3 py-1 text-xs transition active:scale-[0.97] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/40";
const pillActive = "border-accent bg-accent/10 font-medium text-accent";
const pillMuted =
  "border-border text-muted-foreground hover:border-foreground/40 hover:text-foreground";
---

<section class="text-center">
  <h1
    class="mx-auto max-w-3xl text-balance font-medium text-4xl tracking-tight sm:text-5xl lg:text-6xl"
  >
    <span class="block">Any store. Any storage.</span>
    <span class="block text-accent">One middleware.</span>
  </h1>

  <p class="mx-auto mt-6 max-w-2xl text-balance text-foreground text-lg">
    Stop rewriting persist glue when you swap zustand for TanStack Store — or
    localStorage for IndexedDB.
  </p>

  <p class="mx-auto mt-4 max-w-2xl text-balance text-muted-foreground">
    Zero-dep
    <code class="mx-0.5 rounded bg-muted px-1.5 font-mono text-sm"
      >persistSource</code
    >
    core; codecs, backends, transport, and framework gates are opt-in subpaths.
  </p>

  <div class="mx-auto mt-8 flex items-center justify-center gap-10">
    <div>
      <div class="font-bold text-3xl text-foreground">3</div>
      <div class="text-muted-foreground text-xs">seams</div>
    </div>
    <div>
      <div class="font-bold text-3xl text-foreground">zero-dep</div>
      <div class="text-muted-foreground text-xs">core</div>
    </div>
    <div>
      <div class="font-bold text-3xl text-foreground">opt-in</div>
      <div class="text-muted-foreground text-xs">peers</div>
    </div>
  </div>

  <div
    class="mx-auto mt-8 flex max-w-3xl flex-wrap items-center justify-center gap-2"
    data-source-pills
  >
    {
      sourceSnippets.map((snippet) => (
        <button
          class={`inline-flex items-center gap-1.5 ${pillBase} ${snippet.id === defaultSourceId ? pillActive : pillMuted}`}
          data-install-command={snippet.installCommand}
          data-source={snippet.id}
          type="button"
        >
          <Icon
            class="size-4 shrink-0 object-contain"
            name={snippet.icon}
            size={16}
          />
          {snippet.label}
        </button>
      ))
    }
  </div>

  <div class="mx-auto mt-6 max-w-2xl text-left">
    {
      sourceSnippets.map((snippet) => (
        <div
          class={snippet.id === defaultSourceId ? undefined : "hidden"}
          data-code={snippet.id}
        >
          <CodeBlock code={snippet.code} lang={snippet.lang} />
        </div>
      ))
    }
  </div>

  <div class="mt-9"><InstallBox /></div>

  <div class="mt-7 flex items-center justify-center gap-6 text-sm">
    <a
      class="inline-flex items-center gap-1 rounded-blume bg-accent px-5 py-2.5 font-medium text-accent-foreground text-sm transition-opacity hover:opacity-90"
      href={contentHref("/guides/getting-started")}
    >
      Get started
      <svg
        class="size-3.5"
        fill="none"
        height="14"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        width="14"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="m9 18 6-6-6-6"></path>
      </svg>
    </a>
    <a
      class="inline-flex items-center gap-1 font-medium text-muted-foreground transition-colors hover:text-foreground"
      href="https://github.com/stainless-code/persist"
      rel="noreferrer"
      target="_blank"
    >
      View the code
      <svg
        class="size-3.5"
        fill="none"
        height="14"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        width="14"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="m9 18 6-6-6-6"></path>
      </svg>
    </a>
  </div>
</section>

<script is:inline>
  (() => {
    const pillContainer = document.querySelector("[data-source-pills]");
    const installBox = document.querySelector("[data-blume-install-box]");
    if (!pillContainer) return;

    const ACTIVE = [
      "border-accent",
      "bg-accent/10",
      "font-medium",
      "text-accent",
    ];
    const MUTED = [
      "border-border",
      "text-muted-foreground",
      "hover:border-foreground/40",
      "hover:text-foreground",
    ];

    pillContainer.addEventListener("click", (e) => {
      const pill = e.target.closest("[data-source]");
      if (!pill) return;

      const source = pill.dataset.source;
      const installCommand = pill.dataset.installCommand;

      pillContainer.querySelectorAll("[data-source]").forEach((p) => {
        const isActive = p.dataset.source === source;
        p.classList.remove(...ACTIVE, ...MUTED);
        p.classList.add(...(isActive ? ACTIVE : MUTED));
      });

      document.querySelectorAll("[data-code]").forEach((block) => {
        if (block.dataset.code === source) {
          block.classList.remove("hidden");
        } else {
          block.classList.add("hidden");
        }
      });

      if (installBox && installCommand) {
        installBox.querySelectorAll("[data-install-cmd]").forEach((block) => {
          if (block.dataset.installCmd === source) {
            block.classList.remove("hidden");
          } else {
            block.classList.add("hidden");
          }
        });
        const copyBtn = installBox.querySelector("[data-blume-copy-install]");
        if (copyBtn) copyBtn.dataset.command = installCommand;
      }
    });
  })();
</script>
